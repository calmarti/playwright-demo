{
  "compilerOptions": {
    /* Basic Options */
    "target": "ESNext",             // Node 22 supports the latest features
    "module": "NodeNext",           // Best for Node 22 ESM/CJS compatibility
    "moduleResolution": "NodeNext", // Explicitly fixes the deprecation warning
    "lib": ["ESNext"],              // Cleaned up (removed DOM)
    
    /* Strictness */
    "strict": true,                 // Includes noImplicitAny and more
    
    /* Compatibility */
    "esModuleInterop": true,
    "skipLibCheck": true, 
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,      // Highly recommended for reading test data/configs

    /* Paths */
    "types": ["node", "@playwright/test"] 
  },
  "include": [
    "features/**/*.ts", 
    "step-definitions/**/*.ts", 
    "setup/**/*.ts",
    "page-objects/**/*.ts"
  ],
  "exclude": ["node_modules"]
}