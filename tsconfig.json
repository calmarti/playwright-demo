{
  "compilerOptions": {
    /* Basic Options */
    "target": "es2020",             // Modern JS for modern Playwright/Node
    "module": "CommonJS",           // Keeps your existing module system
    "moduleResolution": "node",     // How TS finds your packages
    "lib": ["ESNext", "DOM"],       // Adds support for modern APIs
    
    /* Strictness - The "Upgrade" part */
    "strict": true,                 // Turns on all type-checking (recommended)
    "noImplicitAny": true,         // Set to true later once you are comfortable
    
    /* Compatibility */
    "esModuleInterop": true,        // Allows easy imports (import fs from 'fs')
    "skipLibCheck": true,           // Faster builds; skips checking node_modules
    "forceConsistentCasingInFileNames": true,

    /* Paths */
    "baseUrl": ".",
    "types": ["node", "@playwright/test", "@cucumber/cucumber"] 
  },
  "include": [
    "features/**/*.ts", 
    "step-definitions/**/*.ts", 
    "setup/**/*.ts",
    "page-objects/**/*.ts"
  ],
  "exclude": ["node_modules"]
}